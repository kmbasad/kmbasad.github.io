---
interface Props {
  title?: string;
  description?: string;
  section?: 'panthea' | 'pangea' | 'translations' | 'trellises' | '';
  bodyClass?: string;
  styles?: string[];
  navTitle?: string;            // page name shown on the right of the nav bar
  navParentHref?: string;       // breadcrumb parent URL
  navParentLabel?: string;      // breadcrumb parent label
  navGrandParentHref?: string;  // optional grandparent URL
  navGrandParentLabel?: string; // optional grandparent label
}

const {
  title = 'KMBA',
  description = 'Khan Muhammad Bin Asad — Panthea, Pangea, Translations, Trellises.',
  section = '',
  bodyClass = '',
  styles = [],
  navTitle = '',
  navParentHref = '',
  navParentLabel = '',
  navGrandParentHref = '',
  navGrandParentLabel = '',
} = Astro.props;

const isHome = Astro.url.pathname === '/';

const links = [
  { href: '/',             label: 'হোম',         active: isHome },
  { href: '/panthea/',     label: 'প্যান্থিয়া',  active: section === 'panthea' },
  { href: '/pangea/',      label: 'প্যাঞ্জিয়া',  active: section === 'pangea' },
  { href: '/translations/',label: 'অনুবাদ',      active: section === 'translations' },
  { href: '/trellises/',   label: 'মাচা',        active: section === 'trellises' },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Apply theme before paint to avoid a flash of the wrong mode -->
    <script is:inline>
      try {
        var _t = localStorage.getItem('kmba-theme') ||
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', _t);
      } catch (e) {}
    </script>

    <!-- Bengali-forward typography (the work is written in Bangla) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+Bengali:wght@300;400;500;600;700&family=Tiro+Bangla:ital@0;1&display=swap"
    />

    <link rel="stylesheet" href="/css/style.css" />
    {styles.map((href) => <link rel="stylesheet" href={href} />)}

    <script is:inline defer src="/js/site.js"></script>

    <slot name="head" />
  </head>

  <body class={bodyClass}>
    <nav class="nav">
      <div class="nav-inner">

        <!-- Left: all navigation links including home -->
        <ul class="nav-links">
          {links.map((l) => (
            <li>
              <a href={l.href} class={l.active ? 'active' : undefined}>{l.label}</a>
            </li>
          ))}
        </ul>

        <!-- Right: current page context + theme toggle -->
        <div class="nav-right">
          {navTitle && (
            <div class="nav-page-info">
              {navGrandParentHref && navGrandParentLabel && (
                <a class="nav-parent" href={navGrandParentHref}>{navGrandParentLabel}</a>
              )}
              {navGrandParentHref && navGrandParentLabel && (
                <span class="nav-sep" aria-hidden="true">›</span>
              )}
              {navParentHref && navParentLabel && (
                <a class="nav-parent" href={navParentHref}>{navParentLabel}</a>
              )}
              {navParentHref && navParentLabel && (
                <span class="nav-sep" aria-hidden="true">›</span>
              )}
              <span class="nav-cur">{navTitle}</span>
            </div>
          )}
          <button class="nav-theme-btn" id="nav-theme-btn" aria-label="Toggle theme"></button>
        </div>

      </div>
    </nav>

    <slot />
  </body>
</html>
