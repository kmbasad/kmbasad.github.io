---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Consciousness: ten thinkers, ten properties — KMBA"
  section="trellises"
  styles={['/css/matrix.css']}
>
  <div class="page-header">
    <div class="page-header-inner">
      <div class="breadcrumb">
        <a href="/trellises/">Trellises</a>
        <span class="sep">/</span>
        <span class="breadcrumb-current">Consciousness</span>
        <span class="breadcrumb-sub">What it is like to be</span>
      </div>
      <div class="toc-wrapper">
        <span class="toc-label">TOC ▾</span>
        <div class="toc-dropdown">
          <ul>
            <li><a href="#part-1">Consciousness through Ten Thinkers</a></li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="page-section" id="part-1">
    <div id="matrix-mount"></div>
    <p class="article-legend">
      Ten thinkers from India, China, Persia, Germany, and the Americas, read through ten
      properties of consciousness across 2,500 years of inquiry. Click any cell to read a
      thinker’s view on one property. Click a property label in the left column for the
      cross-tradition synthesis. Click a thinker’s name in the top row for their complete
      account. Press Escape to close a panel.
    </p>
  </div>

  <script is:inline>
    window.MATRIX_CONFIG = { src: 'consciousness.md', mountId: 'matrix-mount' };
  </script>
  <script is:inline src="/js/matrix.js"></script>
</Base>
