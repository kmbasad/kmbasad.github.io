---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Consciousness: ten thinkers, ten properties — KMBA"
  section="trellises"
  styles={['/css/trellis.css']}
  navTitle="চেতনা" navParentHref="/trellises/" navParentLabel="মাচা"
>

  <div class="page-section">
    <h1 class="work-title">চেতনা</h1>
    <div id="trellis-mount"></div>
  </div>

  <section class="trellis-essay">
    <div id="essay-mount"></div>
  </section>

  <script is:inline>
    window.TRELLIS_CONFIG = { data: 'trellis.md', essay: 'essay.md', mountId: 'trellis-mount' };
  </script>
  <script is:inline src="/js/trellis.js"></script>
</Base>
