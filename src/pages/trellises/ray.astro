---
import Base from '../../layouts/Base.astro';
---

<Base title="Ray, Satyajit — KMBA" section="trellises" styles={['/css/trellis.css']}
  navTitle="সত্যজিৎ রায়" navParentHref="/trellises/" navParentLabel="মাচা"
>
  <Fragment slot="head">
    <!-- Bangla essay block — runtime-injected by trellis.js, so the rules must be global -->
    <style is:global>
      .essay-bn .section-title { font-weight: 300; }
      .essay-bn .essay-body p { font-weight: 400; line-height: 2.0; }
      .essay-bn .essay-body > p:first-child::first-letter {
        float: none; font-size: inherit; line-height: inherit;
        font-weight: inherit; padding: 0; color: inherit;
      }
    </style>
  </Fragment>

  <div class="page-section">
    <h1 class="work-title">সত্যজিৎ রায়</h1>
    <div id="trellis-mount"></div>
  </div>

  <section class="trellis-essay essay-bn">
    <div id="essay-mount"></div>
  </section>

  <script is:inline>
    window.TRELLIS_CONFIG = { data: 'trellis.md', essay: 'essay.md', mountId: 'trellis-mount' };
  </script>
  <script is:inline src="/js/trellis.js"></script>
</Base>
