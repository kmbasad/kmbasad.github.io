---
import Base from '../../layouts/Base.astro';
---

<Base
  title="God: a journey to the fountain of existence — KMBA"
  section="trellises"
  styles={['/css/matrix.css']}
>
  <div class="page-header">
    <div class="page-header-inner">
      <div class="breadcrumb">
        <a href="/trellises/">Trellises</a>
        <span class="sep">/</span>
        <span class="breadcrumb-current">God</span>
        <span class="breadcrumb-sub">A Journey to the Fountain of Existence</span>
      </div>
    </div>
  </div>

  <div class="page-section" id="part-1">
    <div id="god-philosophers-mount"></div>
    <p class="article-legend">
      Ten philosophers from across the world, read through ten properties of the divine across
      2,500 years of inquiry. Click any cell to read a philosopher&#8217;s treatment of one property.
      Click a property label in the left column for the cross-tradition synthesis. Click a
      philosopher&#8217;s name in the top row for their complete God-concept. Press Escape to close a panel.
    </p>
  </div>

  <div class="page-section" id="part-2">
    <div id="god-prophets-mount"></div>
    <p class="article-legend">
      Ten prophets and sacred poets from Egypt, Iran, Israel, Greece, China, India, Arabia, and
      Punjab, read through ten properties of the divine as lived, proclaimed, and sung across 3,000
      years. Click any cell to read a prophet&#8217;s vision of one property. Click a property label for
      the cross-tradition synthesis. Click a prophet&#8217;s name for their complete God-vision. Press
      Escape to close a panel.
    </p>
  </div>

  <div class="page-section" id="part-3">
    <div id="essay-mount"></div>
  </div>

  <!-- bespoke matrix + trellis-flora engine, loaded unprocessed (is:inline) -->
  <script is:inline>
    window.GOD_DATA = [
      { src: 'god-philosophers.md', mountId: 'god-philosophers-mount' },
      { src: 'god-prophets.md', mountId: 'god-prophets-mount' }
    ];
    window.ESSAY_SRC = 'god-essay.md';
  </script>
  <script is:inline src="/js/matrix.js"></script>
</Base>
