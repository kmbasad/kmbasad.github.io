---
import Base from '../../../layouts/Base.astro';
---

<Base title="Inferno I — KMBA" section="translations" styles={['/css/translation-table.css']}>
  <Fragment slot="head">
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div class="page-header">
    <div class="page-header-inner">
      <div class="breadcrumb">
        <a href="/translations/">Translations</a>
        <span class="sep">/</span>
        <a href="/translations/divine-comedy/">Dante's Divine Comedy</a>
        <span class="sep">/</span>
        <span class="breadcrumb-current">Inferno</span>
        <span class="breadcrumb-sub">Canto I</span>
      </div>
    </div>
  </div>

  <div class="trans-page wide">
    <div class="tt-wrap">
      <table class="tt-table">
        <thead><tr></tr></thead>
        <tbody></tbody>
      </table>
    </div>
  </div>

  <script is:inline>
    window.TSV_CONFIG = { src: 'inferno-01.tsv', type: 'tercet', dictSrc: 'inferno-01-words.tsv' };
  </script>
  <script is:inline src="/js/tsv-loader.js"></script>
  <script is:inline src="/js/translation-table.js"></script>
</Base>
