---
import Base from '../../../layouts/Base.astro';
import { translationWorks } from '../../../data/translation-works.js';

const work = translationWorks.find((w) => w.slug === 'divine-comedy')!;

function toBn(n: number): string {
  return String(n).replace(/[0-9]/g, (d) => '০১২৩৪৫৬৭৮৯'[Number(d)]);
}

const canticles = [
  { title: 'দোজখ',    slug: 'inferno',    count: 34, existing: new Set(['inferno-01']) },
  { title: 'আরাফ',    slug: 'purgatorio', count: 33, existing: new Set<string>() },
  { title: 'বেহেশ্ত', slug: 'paradiso',   count: 33, existing: new Set<string>() },
];
---

<Base
  title="Dante's Divine Comedy — KMBA"
  section="translations"
  navTitle="ডিভাইন কমেডি"
  navParentHref="/translations/"
  navParentLabel="অনুবাদ"
>
  <div class="main">
    <h1 class="work-title">{work.title}</h1>

    <div class="dc-canticles">
      {canticles.map((c) => (
        <div class="dc-canticle">
          <p class="dc-canticle-label">{c.title}</p>
          <div class="canto-grid">
            {Array.from({ length: c.count }, (_, i) => {
              const n = i + 1;
              const slug = `${c.slug}-${String(n).padStart(2, '0')}`;
              const bn = toBn(n);
              return c.existing.has(slug)
                ? <a href={`/translations/divine-comedy/${slug}/`} class="canto-num">{bn}</a>
                : <span class="canto-num canto-num--off">{bn}</span>;
            })}
          </div>
        </div>
      ))}
    </div>
  </div>
</Base>
