---
import Base from '../../../layouts/Base.astro';
---

<Base
  title="Metamorphoses I — KMBA"
  section="translations"
  styles={['/css/translation-table.css']}
>
  <Fragment slot="head">
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div class="page-header">
    <div class="page-header-inner">
      <div class="breadcrumb">
        <a href="/translations/">Translations</a>
        <span class="sep">/</span>
        <a href="/translations/metamorphoses/">Ovid's Metamorphoses</a>
        <span class="sep">/</span>
        <span class="breadcrumb-current">Book I</span>
      </div>
    </div>
  </div>

  <div class="trans-page wide">
    <div class="tt-wrap">
      <table class="tt-table">
        <thead><tr></tr></thead>
        <tbody></tbody>
      </table>
    </div>
  </div>

  <!-- bespoke TSV engine, loaded unprocessed (is:inline) exactly as the legacy page did -->
  <script is:inline>
    window.TSV_CONFIG = { src: 'book-i.tsv', type: 'tercet' };
  </script>
  <script is:inline src="/js/tsv-loader.js"></script>
  <script is:inline src="/js/translation-table.js"></script>
</Base>
