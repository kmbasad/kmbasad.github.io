---
import Base from '../../../layouts/Base.astro';
import { translationWorks } from '../../../data/translation-works.js';

const work = translationWorks.find((w) => w.slug === 'metamorphoses')!;
---

<Base title="Ovid's Metamorphoses — KMBA" section="translations"
  navTitle="মেটামর্ফোসিজ" navParentHref="/translations/" navParentLabel="অনুবাদ"
>

  <div class="main">
    <h1 class="work-title">{work.title}</h1>

    <div class="listing-box">
      <!-- ARTICLES_START -->
      <a class="listing-item" href="/translations/metamorphoses/book-i/">
        <span class="title">প্রথম বই</span>
      </a>
      <!-- ARTICLES_END -->
    </div>
  </div>
</Base>
