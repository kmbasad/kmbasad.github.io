---
import Base from '../../layouts/Base.astro';
import { translationWorks } from '../../data/translation-works.js';
---

<Base title="Translations — KMBA" section="translations">

  <div class="main">
    <h1 class="work-title">অনুবাদ</h1>
    <div class="listing-box">
      {translationWorks.map((w) => (
        <a class="listing-item" href={`/translations/${w.slug}/`}>
          <span class="title">{w.title}</span>
        </a>
      ))}
    </div>
  </div>
</Base>
