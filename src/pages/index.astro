---
import Base from '../layouts/Base.astro';
---

<Base title="KMBA" bodyClass="home-page" styles={['/css/home.css']}>
  <canvas id="home-canvas" aria-hidden="true"></canvas>

  <div class="home-stage">
    <div class="home-center">
      <h1 class="home-name">Khan Muhammad Bin Asad</h1>
      <p class="home-tagline">A personal journey into the collective unconscious</p>

      <div class="home-divider"></div>

      <nav class="home-sections">
        <a href="/panthea/" class="home-section">
          <span class="home-section-label">Panthea</span>
          <span class="home-section-sub">The epic, in Bangla</span>
        </a>
        <a href="/canon/" class="home-section">
          <span class="home-section-label">Canon</span>
          <span class="home-section-sub">Canonical Bangla texts · Alaol</span>
        </a>
        <a href="/translations/" class="home-section">
          <span class="home-section-label">Translations</span>
          <span class="home-section-sub">Hafez · Dante · Ovid · Rumi</span>
        </a>
        <a href="/trellises/" class="home-section">
          <span class="home-section-label">Trellises</span>
          <span class="home-section-sub">Consciousness · God · Cinema</span>
        </a>
      </nav>

      <div class="home-meta">
        <a href="mailto:kasad@iub.edu.bd">kasad@iub.edu.bd</a>
        <span class="home-meta-sep">·</span>
        <a href="https://cassa.site/people/asad/">cassa.site/people/asad</a>
        <span class="home-meta-sep">·</span>
        <a href="https://www.facebook.com/kmbasad">Facebook</a>
      </div>

      <p class="home-license">
        <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/">CC BY-NC-SA 4.0</a>
      </p>
    </div>
  </div>

  <script is:inline>
    (function () {
      var canvas = document.getElementById('home-canvas');
      if (!canvas) return;
      var ctx = canvas.getContext('2d');
      var stars = [];
      var raf = null;
      var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var PALETTE = ['#fff4df', '#ffe9c8', '#ffd9a0', '#f6c073', '#e0913f'];

      function resize() {
        var dpr = window.devicePixelRatio || 1;
        var w = window.innerWidth, h = window.innerHeight;
        canvas.width = Math.round(w * dpr);
        canvas.height = Math.round(h * dpr);
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        spawn(w, h);
      }

      function spawn(w, h) {
        var count = Math.max(160, Math.min(Math.floor(w * h / 3600), 420));
        stars = [];
        for (var i = 0; i < count; i++) {
          var roll = Math.random();
          var big = roll < 0.04, mid = roll < 0.38;
          stars.push({
            x: Math.random() * w, y: Math.random() * h,
            r: big ? (1.1 + Math.random() * 0.9) : mid ? (0.6 + Math.random() * 0.55) : (0.18 + Math.random() * 0.44),
            base: big ? (0.70 + Math.random() * 0.25) : mid ? (0.40 + Math.random() * 0.28) : (0.10 + Math.random() * 0.28),
            speed: 0.35 + Math.random() * 1.3,
            phase: Math.random() * 6.2832,
            color: PALETTE[Math.floor(Math.random() * PALETTE.length)]
          });
        }
      }

      function paint(ts) {
        var w = window.innerWidth, h = window.innerHeight;
        ctx.clearRect(0, 0, w, h);
        var t = (ts || 0) * 0.001;
        for (var i = 0; i < stars.length; i++) {
          var s = stars[i];
          var a = reduced ? s.base : s.base * (1 + 0.22 * Math.sin(t * s.speed + s.phase));
          ctx.globalAlpha = Math.max(0.02, Math.min(1, a));
          ctx.fillStyle = s.color;
          ctx.beginPath();
          ctx.arc(s.x, s.y, s.r, 0, 6.2832);
          ctx.fill();
        }
        ctx.globalAlpha = 1;
        if (!reduced) raf = requestAnimationFrame(paint);
      }

      function isDark() { return document.documentElement.getAttribute('data-theme') !== 'light'; }

      function sync() {
        if (isDark()) {
          canvas.style.opacity = '1';
          if (!raf) { if (reduced) { paint(0); } else { raf = requestAnimationFrame(paint); } }
        } else {
          canvas.style.opacity = '0';
          if (raf) { cancelAnimationFrame(raf); raf = null; }
        }
      }

      new MutationObserver(sync).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

      var resizeTimer;
      window.addEventListener('resize', function () {
        clearTimeout(resizeTimer);
        if (raf) { cancelAnimationFrame(raf); raf = null; }
        resizeTimer = setTimeout(function () { resize(); sync(); }, 60);
      });

      resize();
      sync();
    }());
  </script>
</Base>
