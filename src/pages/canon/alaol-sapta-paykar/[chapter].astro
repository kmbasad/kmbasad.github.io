---
import Base from '../../../layouts/Base.astro';
import { alaolChapters } from '../../../data/alaol-chapters.js';

export function getStaticPaths() {
  return alaolChapters.map((c) => ({
    params: { chapter: c.slug },
    props: { en: c.en },
  }));
}

const { chapter } = Astro.params;
const { en } = Astro.props;
---

<Base
  title={`${en} — Alaol's Sapta Paykar — KMBA`}
  section="canon"
  styles={['/css/translation-table.css']}
>
  <div class="page-header">
    <div class="page-header-inner">
      <div class="breadcrumb">
        <a href="/canon/">Canon</a>
        <span class="sep">/</span>
        <a href="/canon/alaol-sapta-paykar/">Alaol's Sapta Paykar</a>
        <span class="sep">/</span>
        <span class="breadcrumb-current">{en}</span>
      </div>
    </div>
  </div>

  <div class="trans-page wide tt-prose">
    <div class="tt-wrap">
      <table class="tt-table">
        <thead><tr></tr></thead>
        <tbody></tbody>
      </table>
    </div>
  </div>

  <!-- define:vars injects the per-chapter TSV path into this inline config script -->
  <script define:vars={{ src: `${chapter}.tsv` }}>
    window.TSV_CONFIG = { src, type: 'tercet' };
  </script>
  <script is:inline src="/js/tsv-loader.js"></script>
  <script is:inline src="/js/translation-table.js"></script>
</Base>
