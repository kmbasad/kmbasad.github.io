---
import Base from '../../../layouts/Base.astro';
import { alaolChapters } from '../../../data/alaol-chapters.js';
---

<Base title="Alaol's Sapta Paykar — KMBA" section="canon">
  <Fragment slot="head">
    <style is:global>
      /* Chapter titles in the listing are Bangla — use the unified Bangla face.
         English subtitle styled as a small-caps tag. */
      .alaol-listing .listing-item .title { font-family: var(--bn-font); letter-spacing: 0; }
      .alaol-listing .listing-item .desc {
        letter-spacing: 0.04em; text-transform: uppercase; font-style: normal;
      }
    </style>
  </Fragment>

  <div class="page-header">
    <div class="page-header-inner">
      <div class="breadcrumb">
        <a href="/canon/">Canon</a>
        <span class="sep">/</span>
        <span class="breadcrumb-current">Alaol's Sapta Paykar</span>
      </div>
    </div>
  </div>

  <div class="main">
    <div class="listing-box alaol-listing">
      {
        alaolChapters.map((c) => (
          <a class="listing-item" href={`/canon/alaol-sapta-paykar/${c.slug}/`}>
            <span class="title">{c.bn}</span>
            <span class="desc">{c.en}</span>
          </a>
        ))
      }
    </div>
  </div>
</Base>
